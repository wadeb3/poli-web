# Copy this file to .env.local (same folder) and fill in your real values.
# .env.local is already in .gitignore — it will never be pushed to GitHub.
# Get both values from your Supabase project: Settings (gear icon) → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
